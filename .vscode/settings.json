{
    // --------------------------------------------------
    // Explorer & Search: hide generated files
    // --------------------------------------------------
    "files.exclude": {
        "**/*.egg-info": true,
        "**/__pycache__": true,
        "**/.ruff_cache": true,
        "**/.pytest_cache": true,
    },
    "search.exclude": {
        "**/*.egg-info": true,
        "**/__pycache__": true,
        "**/.ruff_cache": true,
        "**/.pytest_cache": true,
    },
    // --------------------------------------------------
    // Global formatting behavior
    // --------------------------------------------------
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {},
    // --------------------------------------------------
    // Ruff extension
    // --------------------------------------------------
    "ruff.enable": true,
    // Disable linting completely
    "ruff.lint.enable": false,
    // --------------------------------------------------
    // Python-specific settings
    // --------------------------------------------------
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {}
    },
    // --------------------------------------------------
    // HTML: disable auto-formatting
    // --------------------------------------------------
    "[html]": {
        "editor.formatOnSave": false
    },
    // --------------------------------------------------
    // Testing
    // --------------------------------------------------
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true
}